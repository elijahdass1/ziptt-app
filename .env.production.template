# === zip.tt Production Environment Variables ===
# Copy this file to .env.production or add to Vercel dashboard

# Database (Neon Postgres — free tier at neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# NextAuth
NEXTAUTH_URL=https://zip.tt
NEXTAUTH_SECRET=generate-with: openssl rand -base64 32

# Google OAuth (optional — console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic Claude (console.anthropic.com)
ANTHROPIC_API_KEY=

# UploadThing (uploadthing.com)
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# WiPay (wipayfinancial.com)
WIPAY_ACCOUNT_NUMBER=
WIPAY_API_KEY=
WIPAY_ENV=live
