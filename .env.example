# zip.tt environment variables
#
# Copy this file to `.env.local` and fill in the values. lib/env.ts
# validates the required block on boot — missing values throw a
# loud, fail-fast error rather than producing 500s at runtime.
#
# In Vercel, set every variable below for ALL THREE environments
# (Production, Preview, Development). Variables with `NEXT_PUBLIC_`
# in the name are bundled into the client — never put a secret there.

# ─── Required ───────────────────────────────────────────────────────

# Postgres connection string. Use a Neon `?sslmode=require` URL.
DATABASE_URL=

# Public origin of the deployed app (no trailing slash).
NEXTAUTH_URL=https://ziptt-prod.vercel.app

# 32-byte random secret for NextAuth session signing.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── OAuth (optional — remove the Google "Sign in with" button if absent) ──

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI (optional — chatbot falls back to canned replies without these) ───

# Used by the customer chat assistant. Free tier is generous.
GROQ_API_KEY=

# Used by some admin tooling.
ANTHROPIC_API_KEY=

# ─── Email — Resend (optional but required to send transactional mail) ────

# resend.com → API keys.
RESEND_API_KEY=

# Verified sender. Defaults to `zip.tt <orders@zip.tt>` — needs your
# domain verified in Resend. Until verified, lib/email.ts auto-falls
# back to onboarding@resend.dev (only delivers to your account email).
RESEND_FROM_EMAIL=

# Where every order-placed admin notification goes. Default is the
# project owner's address.
ADMIN_NOTIFY_EMAIL=elijah.dass1@gmail.com

# ─── Image uploads — UploadThing ──────────────────────────────────────────

# uploadthing.com → API keys.
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# ─── Payments — WiPay ─────────────────────────────────────────────────────

# When unset, /api/payments/wipay returns a mock URL so checkout flows
# work locally. Set both for sandbox testing in staging.
WIPAY_ACCOUNT_NUMBER=
WIPAY_API_KEY=

# Switches WiPay endpoint. Defaults to "sandbox". Set to "live" only
# when you're ready to take real money. The route reads this at
# request time so flipping in Vercel needs no redeploy.
#   sandbox → https://sandbox.wipayfinancial.com/v1/gateway
#   live    → https://wipayfinancial.com/v1/gateway
WIPAY_ENV=sandbox

# ─── Public feature flags ─────────────────────────────────────────────────

# Anything prefixed NEXT_PUBLIC_ is bundled to the client. Never put
# secrets here. Booleans only.

# Toggle the AI chat widget on/off platform-wide.
NEXT_PUBLIC_CHAT_ENABLED=true
